# Claude agents shared env file. Sourced by both meal-checker and tg-notify.
# Location on installed machine: ~/.config/claude-tools/env

# Amazon employee meal ordering login email (meal-checker)
export MEAL_CHECKER_EMAIL='you@amazon.com'

# Telegram bot credentials (tg-notify)
# Create a bot via @BotFather, send it /start, then look up your chat id
# by sending any message and visiting
# https://api.telegram.org/bot<TOKEN>/getUpdates
export TG_BOT_TOKEN='123456:ABCDEF-your-bot-token'
export TG_CHAT_ID='123456789'
